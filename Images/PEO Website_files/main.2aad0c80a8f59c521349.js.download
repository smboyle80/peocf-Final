            url
          }
        }
      }
      ... on ImageModule {
        id
        projectId
        __typename
        src
        url
        flexHeight
        flexWidth
        project {
          name
          covers {
            size_202 {
              url
            }
            size_404 {
              url
            }
            size_808 {
              url
            }
            size_max_808 {
              url
            }
          }
        }
        imageSizes {
          size_disp {
