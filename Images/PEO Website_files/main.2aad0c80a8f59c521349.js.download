    search(query: $query, type: IMAGE, filter: $filter, first: $first, after: $after, alwaysHasNext: true) {
      pageInfo {
        hasNextPage
        endCursor
      }
      nodes {
        ... on ImageModule {
          __typename
          id
          src
          flexWidth
          flexHeight
          height
          width
          tags
          colors {
            r
            g
            b
          }
          exifData {
            makeAndModel {
