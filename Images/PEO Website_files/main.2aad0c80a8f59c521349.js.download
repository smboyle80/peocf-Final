          actor {
            ...ActorData
          }
          collection {
            ...CollectionData
          }
          project {
            ...ProjectData
          }
        }
        ... on ProjectCommentAction {
          actor {
            ...ActorData
          }
          comment {
            comment
          }
          project {
            ...ProjectData
          }
        }
        ... on StoryFirstPostAction {
          actor {
            ...ActorData
          }
          segment {
            ...SegmentData
          }
        }
