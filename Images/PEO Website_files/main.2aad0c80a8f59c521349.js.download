        query AdobeProjects(
          $projectId: Int!
          $hasProjectId: Boolean!
          $isFromInternalRoute: Boolean!
          $categoryId: Int!
          $shouldLoadSubCategory: Boolean!
          $shouldLoadTopCategory: Boolean!
          $projectsToRenderPerPage: Int!
        ) {
          commissionedProject(id: $projectId) @include(if: $hasProjectId) {
            id
            title
            status
            budgetMin
            budgetMax
            description
            timeline
            expirationDate
            type
            categories {
              id
              name
            }
            appliedOnDate
            attachedFiles {
              renditionUrl
              assetId
              title
              mimeType
              extension
              sourceWidth
              size
            }
            owner {
              id
              username
              displayName
              isCommissionedProjectHirer
              images {
                allAvailable {
                  url
                  width
                  height
                }
              }
            }
          }

          siteConfig @skip(if: $isFromInternalRoute) {
            viewerConfig {
              countryCodeFromIp
              profileCountryCode
            }
          }

          subCategoryProjects: commissionedProjects(
            after: ""
            first: $projectsToRenderPerPage
            categoryId: $categoryId
            status: CREATED
          ) @include(if: $shouldLoadSubCategory) {
            ...commissionedProjectsFields
          }

          commissionedProjects(after: "", first: $projectsToRenderPerPage, status: CREATED)
            @include(if: $shouldLoadTopCategory) {
            ...commissionedProjectsFields
          }

          freelanceServiceOptions {
            categories {
              name
              children {
                id
              }
            }
          }
        }

        ${o.rT}
