posal(upsellEligible: true)\n          freelanceProjectUserInfo {\n            completedProjectCount\n            fullyPaidProjectCount: completedProjectCount(statuses: [COMPLETE])\n            canceledProjectCount: completedProjectCount(statuses: [CANCELED])\n            reviewCount\n            completedProjects @include(if: $shouldPrefetchReviews) {\n              ...completedProjectsFields\n            }\n            projectsWithMe(statuses: [ACCEPTED, CANCELED, COMPLETE, DECLINED, DISCARDED, NEW])\n              @include(if: $shouldPrefetchReviews) {\n              ... on FreelanceProject {\n                ...freelanceFields\n              }\n            }\n            reviews @include(if: $shouldPrefetchReviews) {\n              ...freelanceProjectReviewsFields\n            }\n          }\n          id\n          username\n          displayName\n          isActive\n          isDeleted\n          isCommissionedProjectHirer\n          url\n          stripeAccount {\n            id\n          }\n          paypalAccount {\n            merchantId\n          }\n          isFollowing\n          isFollowedBy\n          isMessageButtonVisible\n          isBlocked\n          blockList {\n            id\n          }\n          firstName\n          country\n          location\n          locationUrl\n          company\n          images {\n            size_50 {\n              url\n            }\n            size_100 {\n              url\n            }\n            size_115 {\n              url\n            }\n            size_230 {\n              url\n            }\n            size_138 {\n              url\n            }\n          }\n          stats {\n            views\n            appreciations\n            followers\n            comments\n            following\n          }\n          projects(first: 4) {\n            nodes {\n              colors {\n                r\n                g\n                b\n              }\n              name\n              covers {\n                size_202 {\n                  url\n                  height\n                  width\n                }\n              }\n            }\n          }\n          createdOn\n          lastName\n          availabilityInfo {\n            availabilityTimeline\n            isAvailableFullTime\n            isAvailableFreelance\n            buttonCTAType\n            compensationMin\n            currency\n            hiringTimeline {\n              key\n              label\n            }\n          }\n          ...creatorProBadgeFields\n        }\n        unreadCount\n        fileAttachmentCount\n        fileAttachments(first: 25) {\n          ...fileAttachmentFields\n        }\n        messages(first: 25, after: $endCursor, before: $startCursor) @skip(if: $shouldLoadWithCursor) {\n          pageInfo {\n            ...pageInfoFields\n          }\n          nodes {\n            createdOn\n            isRead\n            isRisky\n            hasDeletedContent\n            hasScamWarning\n            message\n            id\n            sender {\n              ...senderFields\n            }\n            attachments {\n              __typename\n              ... on JobItem {\n                ...jobItemFields\n              }\n              ... on InboxHireMeData {\n                ...hireMeDataFields\n              }\n              ... on ExpiredStorySegment {\n                id\n              }\n              ... on StorySegment {\n                ...storySegmentFields\n              }\n              ... on FreelanceProject {\n                ...freelanceFields\n                brief {\n                  ...DetailPanel_FreelanceBriefPublicInfo\n                }\n              }\n              ... on FreelanceProjectUpdateAttachment {\n                ...freelanceProjectUpdateFields\n              }\n              ... on JobUpdateAttachment {\n                projectStatus: status\n              }\n              ... on FreelancePaymentRequestAttachment {\n                ...freelancePaymentRequestAttachmentFields\n              }\n              ... on FreelancePayment {\n                ...freelancePaymentFields\n              }\n              ... on InboxFileAttachment {\n                ...inboxFileAttachmentFields\n              }\n              ... on FreelanceServiceRequest {\n                ...freelanceServiceAttachmentFields\n              }\n              ... on InvalidFreelanceServiceRequest {\n                ...invalidFreelanceServiceRequestFields\n              }\n              ... on MeetingAttachment {\n                ...MeetingCard_MeetingAttachment\n              }\n              ... on ScheduledMeetingAttachment {\n                ...ScheduleMeetingCard_ScheduledMeetingAttachment\n              }\n              ... on FreelanceBriefPublicInfo {\n                ...inboxBriefFields\n              }\n              ... on InvalidFreelanceBriefInvite {\n                brief {\n                  ...inboxBriefFields\n                }\n              }\n              ... on JobInvite {\n                ...FulltimeJobInviteCard_JobInvite\n              }\n              ... on InvalidJobInviteMessageAttachment {\n                ...FulltimeJobInviteCard_InvalidJobInviteMessageAttachment\n              }\n            }\n          }\n        }\n        messagesWithCursor(first: 20, id: $messageId) @include(if: $shouldLoadWithCursor) {\n          pageInfo {\n            ...pageInfoFields\n          }\n          nodes {\n            createdOn\n            isRead\n            isRisky\n            hasDeletedContent\n            hasScamWarning\n            message\n            id\n            sender {\n              ...senderFields\n            }\n            attachments {\n              __typename\n              ... on JobItem {\n                ...jobItemFields\n              }\n              ... on InboxHireMeData {\n                ...hireMeDataFields\n              }\n              ... on ExpiredStorySegment {\n   