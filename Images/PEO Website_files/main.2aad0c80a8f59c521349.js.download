          }
        }
        ... on StoryUserReengagedAction {
          actor {
            ...ActorData
          }
          segment {
            ...SegmentData
          }
        }
        ... on UserMentionProjectCommentAction {
          actor {
            ...ActorData
          }
          project {
            ...ProjectData
          }
          comment {
            comment
          }
        }
        ... on FreelanceProjectReviewedAction {
          actor {
            ...ActorData
          }
          review {
            review
          }
        }
        ... on FreelanceProjectReviewReplySentAction {
          actor {
            ...ActorData
          }
          review {
            reply
          }
        }
        ... on ScheduledProjectPublishedAction {
          actor {
            ...ActorData
          }
          project {
            ...ProjectData
            publishedOn
          }
        }
        ... on FreelanceBriefApplicationAction {
          actor {
            ...ActorData
          }
          brief {
            id
            title
          }
        }
        ... on StillHiringCheckAction {
          brief {
            id
            title
            url
            isActive
            respondedOn
          }
        }
        ... on ScheduledMeetingReminderAction {
          actor {
            ...ActorData
          }
          meeting {
            id
            startTime
            url
            threadId
          }
        }
        ... on UserAnalyticsPerformanceUpdateAction @include(if: $includeAdvancedAnalytics) {
          actor {
            ...ActorData
          }
          analytics {
            ... on SearchTermAnalyticPerformance {
              searchTerms {
                term
                count
              }
            }
          }
        }
        ... on MilestoneEarnedAction @include(if: $includeMilestoneEarned) {
          milestone {
            type
            description
            shareUrl
            projectFeature {
              ribbon {
                image
              }
              name
            }
            iconImages {
              sizeOriginal {
                url
                height
                width
                type
              }
            }
          }
        }
      }
    }
  }
