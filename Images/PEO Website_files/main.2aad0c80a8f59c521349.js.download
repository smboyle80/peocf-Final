  query defaultLayoutPrefetch(
    $isLoggedIn: Boolean!
    $disableAnnouncements: Boolean!
    $shouldFetchUser: Boolean!
    $username: String!
    $shouldCheckFreelanceJobsViewed: Boolean!
    $shouldFetchOffers: Boolean!
    $includeHireIncentiveBanner: Boolean!
    $includeBackToSchoolCCPromo: Boolean!
    $includeEcommerceEligible: Boolean!
    $includeIsRestrictedForAIUse: Boolean!
  ) {
    announcements @include(if: $isLoggedIn) @skip(if: $disableAnnouncements) {
      id
      createdOn
      header
      title
      description
      href
      image
      promotionStart
      promotionEnd
      ctaText
    }
    user(username: $username) @include(if: $shouldFetchUser) {
      profileCustomizationSettings {
        theme
      }
    }
    viewer @include(if: $isLoggedIn) {
      hasSubscriptions
      hasBeenHiredForCommissionedProject
      unreadInboxInquiry {
        id
        threadId
        createdOn
        message
        sender {
          id
          url
          displayName
          images {
            size_115 {
              url
              height
              width
            }
          }
        }
      }
      availabilityInfo {
        isAvailableFullTime
        isAvailableFreelance
        hiringTimeline {
          key
          label
        }
        categories {
          name
        }
        budgetMax
        budgetMin
      }
      creatorPro {
        expiresOn
        initialSubscriptionDate
      }
      flags {
        lastDismissedAnnouncement
        shouldSeeSwapConfirmation
        onboardedAsHirer
        onboardedAsCreative
        hasDismissedPaymentConnectionInfoModal
        hasViewedRecommendedFreelanceJobs @include(if: $shouldCheckFreelanceJobsViewed)
        hasViewed30DayGiftOffer
        hasViewed30DayGiftExpiration
        hasViewedMilestonesTab
        didDismissRecruiterProFloatingCta
      }
      payments @include(if: $includeHireIncentiveBanner) {
        hasPaidFreelancers
      }
      stripeAccount @include(if: $includeHireIncentiveBanner) {
        country
      }
      paypalAccount @include(if: $includeHireIncentiveBanner) {
        country
      }
      country @include(if: $includeHireIncentiveBanner)
      isEligibleForBackToSchoolCCPromo @include(if: $includeBackToSchoolCCPromo)
    }
    offers @include(if: $shouldFetchOffers) {
      creatorPro {
        isFallback
      }
    }
    siteConfig {
      viewerConfig {
        isCountryTrialEligible
        isCountryEcommerceSupported @include(if: $includeEcommerceEligible)
        isRestrictedForAIUse @include(if: $includeIsRestrictedForAIUse)
      }
    }
  }
