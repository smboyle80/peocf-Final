riefFields on FreelanceBriefPublicInfo {\n    budgetMax\n    budgetMin\n    company\n    companyUrl\n    companyLogo {\n      size_180 {\n        url\n      }\n    }\n    briefDescription: description\n    deliverables @include(if: $shouldFetchStructuredBriefFields)\n    designStyle @include(if: $shouldFetchStructuredBriefFields)\n    candidateInfo @include(if: $shouldFetchStructuredBriefFields)\n    additionalDetails @include(if: $shouldFetchStructuredBriefFields)\n    id\n    title\n    briefType: type\n    modifiedOn\n    isClosed\n    isRestrictedToOwner\n    isFromRecommendation\n    briefStatus: status\n    briefTimeline: timeline\n    briefAttachedFiles: attachedFiles {\n      assetId\n      renditionUrl\n      title\n      size\n      sourceWidth\n      extension\n      mimeType\n    }\n    owner {\n      displayName\n      username\n      id\n      url\n      images {\n        allAvailable {\n          width\n          url\n        }\n      }\n    }\n  }\n":r.Qaj,"\n  query getAllowedInboxFileExtensionToMimeType {\n    siteConfig {\n      fileExtensionToMimeTypeMap {\n        inbox\n      }\n    }\n  }\n":r.TvP,"\n  fragment invalidFreelanceServiceRequestFields on InvalidFreelanceServiceRequest {\n    serviceId: id\n    company\n    invalidFreelanceServiceTimeline: clientTimeline\n  }\n":r.YvK,"\n  fragment unreadThreadCountsFields on Viewer {\n    unreadInboxThreadCounts: inboxThreadCounts(unreadOnly: true) {\n      inbox\n      inquiries\n      archive\n      messageRequests\n    }\n  }\n":r.IzM,"\n  query InboxThreads(\n    $first: Int = 20\n    $endCursor: String\n    $isArchived: Boolean\n    $boxLocation: InboxBoxLocationType\n    $hasInquiry: Boolean\n  ) {\n    viewer {\n      id\n      allThreads: inboxThreads(filter: { includeFlagged: true, isArchived: false }) {\n        nodes {\n          id\n        }\n      }\n      inquiriesThreads: inboxThreads(filter: { includeFlagged: true, isArchived: false, hasInquiry: true }) {\n        nodes {\n          id\n        }\n      }\n      inboxThreadCounts {\n        inbox\n        inquiries\n        archive\n        messageRequests\n      }\n      ...unreadThreadCountsFields\n      inboxThreads(\n        first: $first\n        after: $endCursor\n        filter: { includeFlagged: true, isArchived: $isArchived, boxLocation: $boxLocation, hasInquiry: $hasInquiry }\n      ) {\n        nodes {\n          # Store-needed fields (explicit)\n          id\n          unreadCount\n          containsInquiry\n          isMessagingEnabled\n          recipients {\n            firstName\n            displayName\n            isActive\n            isDeleted\n          }\n\n          # Component display fields (via fragment)\n          ...ThreadList_InboxThread\n        }\n        pageInfo {\n          ...pageInfoFields\n        }\n      }\n    }\n  }\n":r.pH5,"\n  query InboxJobsNoFilter($endCursor: String, $first: Int = 2) {\n    viewer {\n      inboxThreadParents(after: $endCursor, first: $first, type: JOB) {\n        nodes {\n          entity {\n            ... on JobItem {\n              id\n              title\n              jobType\n            }\n          }\n          count {\n            total\n            new\n          }\n        }\n        pageInfo {\n          ...pageInfoFields\n        }\n      }\n    }\n  }\n":r.Owi,"\n  query InboxJob(\n    $jobId: Int!\n    $endCursor: String\n    $isArchived: Boolean\n    $isShortlisted: Boolean\n    $shouldIncludeCommissionedProject: Boolean = false\n    $shouldFetchStructuredBriefFields: Boolean = false\n  ) {\n    viewer {\n      inboxThreadParent(id: $jobId, type: JOB) {\n        entity {\n          ... on JobItem {\n            title\n            jobType\n            postedOn\n            id\n            company {\n              name\n            }\n            creator {\n              displayName\n            }\n            url\n            expiresOn\n            isExpired\n            archivedOn\n          }\n        }\n        count {\n          new\n          total\n        }\n        children(after: $endCursor, filter: { isArchived: $isArchived, isShortlisted: $isShortlisted }) {\n          nodes {\n            id\n            unreadCount\n            isShortlistedForJob\n            createdOn\n            recipients {\n              ...RecipientNames_User\n              isFeaturedFreelancer\n              displayName\n              id\n              images {\n                ...ModalHeader_UserImageSizes\n                size_50 {\n                  url\n                }\n                size_100 {\n                  url\n                }\n                size_115 {\n                  url\n                }\n                size_230 {\n                  url\n                }\n                size_138 {\n                  url\n                }\n              }\n              freelanceProjectUserInfo {\n                completedProjectCount\n                fullyPaidProjectCount: completedProjectCount(statuses: [COMPLETE])\n                canceledProjectCount: completedProjectCount(statuses: [CANCELED])\n                reviewCount\n                completedProjects {\n                  ...completedProjectsFields\n                }\n                projectsWithMe {\n                  ... on FreelanceProject {\n                    ...freelanceFields\n                  }\n                }\n                reviews {\n                  ...freelanceProjectReviewsFields\n                }\n              }\n            }\n            messages(first: 1) {\n              nodes {\n                message\n                createdOn\n                sender {\n                  id\n                }\n              }\n            }\n            ...ThreadList_InboxThread\n            ...SidebarHeader_InboxThread\n          }\n          pageInfo {\n            ...pageInfoFields\n          }\n        }\n      }\n      archiveThreads: inboxThreadParent(boxLocation: ARCHIVE, id: $jobId, type: JOB) {\n        count {\n          total\n          new\n        }\n        children(after: $endCursor, filter: { isArchived: true, isShortlisted: false }) {\n          nodes {\n            id\n          }\n        }\n      }\n      regularThreads: inboxThreadParent(boxLocation: INBOX, id: $jobId, type: JOB) {\n        count {\n          total\n          new\n        }\n        children(after: $endCursor, filter: { isArchived: false, isShortlisted: false }) {\n          nodes {\n            id\n          }\n        }\n      }\n      shortlistThreads: inboxThreadParent(boxLocation: SHORTLIST, id: $jobId, type: JOB) {\n        count {\n          total\n          new\n        }\n        children(after: $endCursor, filter: { isArchived: false, isShortlisted: true }) {\n          nodes {\n            id\n          }\n        }\n      }\n    }\n  }\n":r.$gB,"\n  query GetInboxSearchResults(\n    $query: query\n    $first: Int!\n    $after: String\n    $filter: SearchResultFilter\n    $shouldGetContactsOnly: Boolean!\n    $shouldGetMessagesOnly: Boolean!\n  ) {\n    messageResults: search(query: $query, type: INBOX_MESSAGE, first: $first, after: $after, filter: $filter)\n      @skip(if: $shouldGetContactsOnly) {\n      pageInfo {\n        hasNextPage\n        endCursor\n      }\n      nodes {\n        ... on InboxMessageSearchResult {\n          message {\n            sender {\n              displayName\n              firstName\n              isActive\n              isDeleted\n            }\n          }\n          inboxThread {\n            # Store-needed fields (explicit)\n            id\n            unreadCount\n            containsInquiry\n            isMessagingEnabled\n            recipients {\n              displayName\n              firstName\n              isActive\n              isDeleted\n            }\n          }\n          ...ThreadList_InboxMessageSearchResult\n        }\n      }\n    }\n\n    contactResults: search(query: $query, type: INBOX_THREAD, first: $first,