      modifiedOn
      status
      hirer {
        username
        displayName
        id
        images {
          size_230 {
            url
          }
        }
        url
      }
      creator {
        username
        displayName
        id
        images {
          allAvailable {
            url
          }
        }
        url
      }
    }
    reviews @include(if: $shouldPrefetchReviews) {
      review
      id
      reply
      freelanceProject {
        id
        status
        modifiedOn
      }
      reviewer {
        id
        username
        displayName
        isCommissionedProjectHirer
        id
        images {
          allAvailable {
            url
          }
        }
        url
      }
    }
  }
