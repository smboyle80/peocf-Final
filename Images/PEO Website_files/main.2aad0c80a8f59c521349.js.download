  query BriefsTodoListQuery($userId: Int, $isLoggedIn: Boolean!, $shouldFetchLearner: Boolean!) {
    viewer {
      paypalAccount {
        status
        merchantId
        hasApprovedCountry
        canSetupPaypal
        country
      }
      stripeAccount {
        id
        status
        canSetupStripe
        hasApprovedCountry
        country
      }
      creativeApprenticeshipCourseLearner @include(if: $shouldFetchLearner) {
        hasCompletedAnyCourse
      }
    }
    siteConfig {
      viewerConfig {
        countryCodeFromIp
        profileCountryCode
      }
    }
    user(id: $userId) @include(if: $isLoggedIn) {
      projects(first: 3) {
        nodes {
          id
        }
      }
    }
  }
`,c=i.Ps`
  query UpdatedViewerQuery {
    viewer {
      occupation
      company
      displayName
      id
      url
      location
      images {
        size_100 {
          url
        }
      }
      socialReferences {
        socialService
        url
        isVerified
        attachments {
          ... on LinkedInVerifiedData {
            isVerified
            name {
              value
              verifiedOn
            }
            company {
              value
              verifiedOn
            }
            jobTitle {
              value
            }
          }
        }
      }
    }
  }
`,u=i.Ps`
  fragment BriefListItemFields on FreelanceBrief {
    id
    title
    status
    isPendingApproval
    budgetMin
    budgetMax
    timeline
    expirationDate
    allowApplications
    isApprovedForPublic
    type
    location {
      continents
      countries
    }
    attachedFiles {
      assetId
      renditionUrl
      title
      size
      sourceWidth
      extension
      mimeType
    }
    candidatesCount {
      saved
      recommended
      contactedOnly
      archived
      applied
    }
    candidates(first: 10, statuses: [RECOMMENDED, SAVED, CONTACTED_ONLY, APPLIED]) {
      nodes {
        inboxThread {
          id
        }
        user {
          id
          displayName
          username
          images {
            allAvailable(useWebpWithFallback: true) {
              url
              type
              width
              height
            }
          }
        }
      }
    }
  }
`,d=i.Ps`
  fragment FreelanceProjectConnectionForBriefsFields on FreelanceProjectConnection {
    pageInfo {
      hasNextPage
      endCursor
    }

    nodes {
      title
      inboxThread {
        id
      }
      creator {
        displayName
        id
        images {
          size_100 {
            url
          }
          size_230 {
            url
          }
        }
      }
      hirer {
        displayName
        id
        images {
          size_100 {
            url
          }
          size_230 {
            url
          }
        }
      }
      unitAmount
      payments {
        breakdown {
          totalAmount
        }
      }
    }
  }
`,p=i.Ps`
  fragment candidatesCountFields on FreelanceBriefCandidateCount {
    archived
    contacted
    contactedOnly
    saved
    recommended
    totalRecommended
    maxRecommendations
    applied
    proposals
  }
`,m=i.Ps`
  fragment candidatesFields on FreelanceBriefCandidateConnection {
    pageInfo {
      endCursor
      hasNextPage
    }
    nodes {
      status
      contactedOn
      wasRecommended
      appliedOn
      hasSentProposal
      inboxThread {
        id
      }
      matchExplainer @include(if: $shouldFetchMatchExplainer) {
        explanation
      }
      user {
        id
        displayName
        url
        username
        creatorPro {
          isActive
        }
        isFeaturedFreelancer
        images {
          allAvailable(useWebpWithFallback: true) {
            url
            type
            width
            height
          }
        }
        isMessageButtonVisible
        availabilityInfo {
          availabilityTimeline
          isAvailableFullTime
          isAvailableFreelance
          hiringTimeline {
            label
          }
          categories(orderByBriefCategories: $orderByBriefId) {
            name
          }
        }
        location
        country
        isResponsiveToHiring
        freelanceProjectUserInfo {
          completedProjectCount
          fullyPaidProjectCount: completedProjectCount(statuses: [COMPLETE])
          canceledProjectCount: completedProjectCount(statuses: [CANCELED])
          reviewCount
        }
        projects(first: 20) {
          nodes {
            id
            slug
            name
            url
            covers {
              allAvailable(useWebpWithFallback: true) {
                type
                height
                width
                url
              }
            }
          }
        }
        freelanceServices {
          nodes {
            ...freelanceServiceFields
          }
        }
      }
    }
  }
  ${o.iX}
`,f=i.Ps`
  query CreateBriefForm(
    $username: String
    $shouldFetchUser: Boolean! = false
    $shouldFetchViewerCountry: Boolean! = false
    $shouldFetchCompanyInfo: Boolean! = false
  ) {
    siteConfig {
      fileExtensionToMimeTypeMap {
        inbox # todo
      }
      viewerConfig @include(if: $shouldFetchViewerCountry) {
        profileCountryCode
      }
    }
    freelanceServiceOptions {
      categories {
        id
        name
        children {
          id
          name
        }
      }
    }
    viewer {
      isCommissionedProjectHirer
      freelanceBriefsPreviousCompanyInfo @include(if: $shouldFetchCompanyInfo) {
        company
        companyUrl
        companyLogoUuid
        companyLogo {
          size_max {
            url
          }
        }
      }
    }
    user(username: $username) @include(if: $shouldFetchUser) {
      availabilityInfo {
        hiringTimeline {
          key
        }
        categories {
          id
          name
        }
      }
    }
  }
`,g=i.Ps`
  fragment proposalsFields on InboxThreadMessageConnection {
    pageInfo {
      hasNextPage
      endCursor
    }
    nodes {
      id
      message
      threadId
      sender {
        id
        url
        username
        displayName
        isMessageButtonVisible
        creatorPro {
          isActive
        }
        stripeAccount {
          id
        }
        images {
          size_100 {
            url
          }
        }
        projects(first: 8) {
          nodes {
            id
            slug
            name
            url
            covers {
              allAvailable(useWebpWithFallback: true) {
                width
                url
                type
              }
